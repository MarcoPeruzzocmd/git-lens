# =============================================================================
# 📁 ARQUIVO: .env.example
# =============================================================================
#
# ▸ O QUE É ESTE ARQUIVO?
#   É o MODELO das variáveis de ambiente do projeto.
#   Variáveis de ambiente são configurações sensíveis (senhas, tokens)
#   que NÃO devem ir para o Git.
#
# ▸ COMO USAR:
#   1. Copiar este arquivo para backend/.env:
#      cp .env.example backend/.env
#   2. Abrir o backend/.env e preencher com seus dados reais
#   3. NUNCA commitar o .env real (já está no .gitignore)
#
# ▸ POR QUE EXISTE:
#   Para que qualquer pessoa que clonar o projeto saiba quais variáveis
#   precisa configurar, sem expor os valores reais.
#
# ▸ VARIÁVEIS:
#
# Token de acesso pessoal do GitHub
# SEM token: limite de 60 requisições/hora (muito pouco)
# COM token: limite de 5.000 requisições/hora
# Como gerar:
#   1. Acesse https://github.com/settings/tokens
#   2. "Generate new token (classic)"
#   3. Marque o escopo "repo"
#   4. Copie o token gerado
GITHUB_TOKEN=

# Configurações do MySQL (devem bater com o docker-compose.yml)
DB_HOST=db
DB_PORT=3306
DB_NAME=gitlens
DB_USER=gitlens_user
DB_PASS=gitlens_pass
